# ============================================================
# Variables de ejemplo — banco de pruebas de on-ramp (Meld widget directo)
# Copia lo que necesites a tu .env.local (que NO se commitea).
# Las variables de producción (Privy, RPC, MoonPay, fee payer) ya viven
# en tu .env.local y no se tocan aquí.
# ============================================================

# Activa la ruta /dev/onramp-meld. Si no está en "true", la página
# muestra "No disponible" (no debe quedar activa en producción).
NEXT_PUBLIC_DEV_TOOLS=true

# RPC de Solana: el banco de pruebas REUTILIZA tus variables existentes
# (NEXT_PUBLIC_DEVNET_RPC / NEXT_PUBLIC_MAINNET_RPC). No hay variables nuevas.
# Devnet ya apunta a tu Helius. Mainnet hoy no está configurado en la app,
# así que el balance poller (que consulta mainnet) cae al RPC público de
# Solana; si te limita el polling cada 15s, define NEXT_PUBLIC_MAINNET_RPC
# con un RPC de mainnet real (p. ej. Helius). No necesitas nada nuevo.


# Meld widget directo: public widget key (sandbox para pruebas, live para
# producción). Es PÚBLICA — va en la URL del widget, no es un secreto.
# Consíguela en el dashboard de meld.io.
NEXT_PUBLIC_MELD_PUBLIC_KEY=

# Opcional: host del widget si Meld te da un sandbox distinto.
# Por defecto: https://meldcrypto.com/
NEXT_PUBLIC_MELD_WIDGET_URL=
